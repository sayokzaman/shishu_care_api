generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  fullNameEn   String?  @map("full_name_en")
  fullNameBn   String?  @map("full_name_bn")
  phone        String   @unique
  email        String?  @unique
  password     String
  role         Role     @default(parent)
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  children     Child[]
  growthRecorded GrowthRecord[] @relation("RecordedBy")
  vaccineAdministered VaccinationRecord[] @relation("AdministeredBy")
  aiQueries    AiQuery[]

  @@map("users")
}

enum Role {
  parent
  health_worker
}

model Division {
  id        Int        @id @default(autoincrement())
  nameEn    String     @map("name_en")
  nameBn    String     @map("name_bn")
  districts District[]

  @@map("divisions")
}

model District {
  id         Int       @id @default(autoincrement())
  divisionId Int       @map("division_id")
  nameEn     String    @map("name_en")
  nameBn     String    @map("name_bn")
  division   Division  @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  upazilas   Upazila[]

  @@map("districts")
}

model Upazila {
  id         Int      @id @default(autoincrement())
  districtId Int      @map("district_id")
  nameEn     String   @map("name_en")
  nameBn     String   @map("name_bn")
  isUrban    Boolean  @default(false) @map("is_urban")
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@map("upazilas")
}

model Child {
  id             Int           @id @default(autoincrement())
  parentId       Int           @map("parent_id")
  name           String
  dateOfBirth    DateTime      @map("date_of_birth") @db.Date
  gender         Gender        @default(male)
  bloodGroup     String?       @map("blood_group")
  birthWeightKg  Decimal?      @map("birth_weight_kg") @db.Decimal(5, 2)
  birthHeightCm  Decimal?      @map("birth_height_cm") @db.Decimal(5, 2)
  journeyType    JourneyType   @default(postnatal) @map("journey_type")
  photoUrl       String?       @map("photo_url")
  createdAt      DateTime      @default(now()) @map("created_at")

  parent             User                @relation(fields: [parentId], references: [id], onDelete: Cascade)
  feedingLogs        FeedingLog[]
  sleepLogs          SleepLog[]
  growthRecords      GrowthRecord[]
  vaccinationRecords VaccinationRecord[]
  milestoneRecords   MilestoneRecord[]
  careLogs           CareLog[]
  aiQueries          AiQuery[]

  @@map("children")
}

enum Gender {
  male
  female
  other
}

enum JourneyType {
  prenatal
  postnatal
}

model FeedingLog {
  id              Int          @id @default(autoincrement())
  childId         Int          @map("child_id")
  type            FeedingType
  durationMinutes Int?         @map("duration_minutes")
  amountMl        Decimal?     @map("amount_ml") @db.Decimal(6, 2)
  side            FeedingSide?
  foodItem        String?      @map("food_item")
  notes           String?      @db.Text
  loggedAt        DateTime     @map("logged_at")
  createdAt       DateTime     @default(now()) @map("created_at")

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("feeding_logs")
}

enum FeedingType {
  breastfeed
  bottle
  solid
}

enum FeedingSide {
  left
  right
  both
}

model SleepLog {
  id              Int           @id @default(autoincrement())
  childId         Int           @map("child_id")
  sleepStart      DateTime      @map("sleep_start")
  sleepEnd        DateTime?     @map("sleep_end")
  durationMinutes Int?          @map("duration_minutes")
  quality         SleepQuality? @default(good)
  notes           String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("sleep_logs")
}

enum SleepQuality {
  poor
  fair
  good
  excellent
}

model GrowthRecord {
  id                   Int      @id @default(autoincrement())
  childId              Int      @map("child_id")
  weightKg             Decimal? @map("weight_kg") @db.Decimal(5, 2)
  heightCm             Decimal? @map("height_cm") @db.Decimal(5, 2)
  headCircumferenceCm  Decimal? @map("head_circumference_cm") @db.Decimal(5, 2)
  measuredAt           DateTime @map("measured_at") @db.Date
  recordedBy           Int?     @map("recorded_by")
  notes                String?  @db.Text
  createdAt            DateTime @default(now()) @map("created_at")

  child    Child  @relation(fields: [childId], references: [id], onDelete: Cascade)
  recorder User?  @relation("RecordedBy", fields: [recordedBy], references: [id], onDelete: SetNull)

  @@map("growth_records")
}

model Vaccination {
  id                  Int                 @id @default(autoincrement())
  name                String
  shortName           String?             @map("short_name")
  recommendedAgeWeeks Int?                @map("recommended_age_weeks")
  description         String?             @db.Text
  isMandatory         Boolean             @default(true) @map("is_mandatory")
  dosesRequired       Int                 @default(1) @map("doses_required")
  records             VaccinationRecord[]

  @@map("vaccinations")
}

model VaccinationRecord {
  id              Int               @id @default(autoincrement())
  childId         Int               @map("child_id")
  vaccinationId   Int               @map("vaccination_id")
  status          VaccinationStatus @default(pending)
  doseNumber      Int               @default(1) @map("dose_number")
  administeredAt  DateTime?         @map("administered_at") @db.Date
  nextDueAt       DateTime?         @map("next_due_at") @db.Date
  administeredBy  Int?              @map("administered_by")
  notes           String?           @db.Text
  createdAt       DateTime          @default(now()) @map("created_at")

  child        Child       @relation(fields: [childId], references: [id], onDelete: Cascade)
  vaccination  Vaccination @relation(fields: [vaccinationId], references: [id])
  admin        User?       @relation("AdministeredBy", fields: [administeredBy], references: [id], onDelete: SetNull)

  @@map("vaccination_records")
}

enum VaccinationStatus {
  pending
  done
  skipped
  overdue
}

model Milestone {
  id          Int               @id @default(autoincrement())
  label       String
  ageMonths   Int               @map("age_months")
  category    MilestoneCategory @default(motor)
  description String?           @db.Text
  icon        String?
  records     MilestoneRecord[]

  @@map("milestones")
}

enum MilestoneCategory {
  motor
  cognitive
  social
  language
}

model MilestoneRecord {
  id          Int      @id @default(autoincrement())
  childId     Int      @map("child_id")
  milestoneId Int      @map("milestone_id")
  achieved    Boolean  @default(false)
  achievedAt  DateTime? @map("achieved_at") @db.Date
  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")

  child     Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  milestone Milestone @relation(fields: [milestoneId], references: [id])

  @@map("milestone_records")
}

model CareLog {
  id            Int      @id @default(autoincrement())
  childId       Int      @map("child_id")
  label         String
  done          Boolean  @default(false)
  scheduledTime String?  @map("scheduled_time")
  completedAt   DateTime? @map("completed_at")
  logDate       DateTime  @map("log_date") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("care_logs")
}

model AiQuery {
  id           Int           @id @default(autoincrement())
  userId       Int           @map("user_id")
  childId      Int?          @map("child_id")
  queryText    String        @map("query_text") @db.Text
  responseText String?       @map("response_text") @db.Text
  queryType    AiQueryType   @default(general) @map("query_type")
  createdAt    DateTime      @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  child Child? @relation(fields: [childId], references: [id], onDelete: SetNull)

  @@map("ai_queries")
}

enum AiQueryType {
  general
  risk_check
  milestone
  vaccination
  nutrition
}
