generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Division {
  id        Int        @id @default(autoincrement())
  nameEn    String     @map("name_en")
  nameBn    String     @map("name_bn")
  districts District[]

  @@map("divisions")
}

model District {
  id         Int        @id @default(autoincrement())
  divisionId Int        @map("division_id")
  nameEn     String     @map("name_en")
  nameBn     String     @map("name_bn")
  division   Division   @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  upazilas   Upazilla[]

  @@index([divisionId], map: "districts_division_id_fkey")
  @@map("districts")
}

model Upazilla {
  id         Int      @id @default(autoincrement())
  districtId Int      @map("district_id")
  nameEn     String   @map("name_en")
  nameBn     String   @map("name_bn")
  isUrban    Boolean  @default(false) @map("is_urban")
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@index([districtId], map: "upazilas_district_id_fkey")
  @@map("upazilas")
}

model User {
  id                  Int                   @id @default(autoincrement())
  email               String?               @unique
  password            String
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  avatar_url          String?
  fullNameBn          String?               @map("full_name_bn")
  fullNameEn          String?               @map("full_name_en")
  phone               String                @unique
  role                users_role            @default(parent)
  ai_queries          ai_queries[]
  children            Child[]
  growth_records      growth_records[]
  vaccination_records vaccination_records[]

  @@map("users")
}

model Child {
  id                  Int                   @id @default(autoincrement())
  parentId            Int                   @map("parent_id")
  name                String
  dateOfBirth         DateTime              @map("date_of_birth") @db.Date
  gender              children_gender       @default(male)
  bloodGroup          String?               @map("blood_group")
  birth_weight_kg     Decimal?              @db.Decimal(5, 2)
  birth_height_cm     Decimal?              @db.Decimal(5, 2)
  journey_type        children_journey_type @default(postnatal)
  photo_url           String?
  createdAt           DateTime              @default(now()) @map("created_at")
  ai_queries          ai_queries[]
  care_logs           care_logs[]
  parent              User                  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  feeding_logs        feeding_logs[]
  growth_records      growth_records[]
  milestone_records   milestone_records[]
  sleep_logs          sleep_logs[]
  vaccination_records vaccination_records[]

  @@index([parentId], map: "children_parent_id_fkey")
  @@map("children")
}

model ai_queries {
  id            Int                   @id @default(autoincrement())
  user_id       Int
  child_id      Int?
  query_text    String                @db.Text
  response_text String?               @db.Text
  query_type    ai_queries_query_type @default(general)
  created_at    DateTime              @default(now())
  children      Child?                @relation(fields: [child_id], references: [id])
  users         User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([child_id], map: "ai_queries_child_id_fkey")
  @@index([user_id], map: "ai_queries_user_id_fkey")
}

model care_logs {
  id             Int       @id @default(autoincrement())
  child_id       Int
  label          String
  done           Boolean   @default(false)
  scheduled_time String?
  completed_at   DateTime?
  log_date       DateTime  @db.Date
  created_at     DateTime  @default(now())
  children       Child     @relation(fields: [child_id], references: [id], onDelete: Cascade)

  @@index([child_id], map: "care_logs_child_id_fkey")
}

model feeding_logs {
  id               Int                @id @default(autoincrement())
  child_id         Int
  type             feeding_logs_type
  duration_minutes Int?
  amount_ml        Decimal?           @db.Decimal(6, 2)
  side             feeding_logs_side?
  food_item        String?
  notes            String?            @db.Text
  logged_at        DateTime
  created_at       DateTime           @default(now())
  children         Child              @relation(fields: [child_id], references: [id], onDelete: Cascade)

  @@index([child_id], map: "feeding_logs_child_id_fkey")
}

model growth_records {
  id                    Int      @id @default(autoincrement())
  child_id              Int
  weight_kg             Decimal? @db.Decimal(5, 2)
  height_cm             Decimal? @db.Decimal(5, 2)
  head_circumference_cm Decimal? @db.Decimal(5, 2)
  measured_at           DateTime @db.Date
  recorded_by           Int?
  notes                 String?  @db.Text
  created_at            DateTime @default(now())
  children              Child    @relation(fields: [child_id], references: [id], onDelete: Cascade)
  users                 User?    @relation(fields: [recorded_by], references: [id])

  @@index([child_id], map: "growth_records_child_id_fkey")
  @@index([recorded_by], map: "growth_records_recorded_by_fkey")
}

model milestone_records {
  id           Int        @id @default(autoincrement())
  child_id     Int
  milestone_id Int
  achieved     Boolean    @default(false)
  achieved_at  DateTime?  @db.Date
  notes        String?    @db.Text
  created_at   DateTime   @default(now())
  children     Child      @relation(fields: [child_id], references: [id], onDelete: Cascade)
  milestones   milestones @relation(fields: [milestone_id], references: [id])

  @@index([child_id], map: "milestone_records_child_id_fkey")
  @@index([milestone_id], map: "milestone_records_milestone_id_fkey")
}

model milestones {
  id                Int                 @id @default(autoincrement())
  label             String
  age_months        Int
  category          milestones_category @default(motor)
  description       String?             @db.Text
  icon              String?
  milestone_records milestone_records[]
}

model sleep_logs {
  id               Int                 @id @default(autoincrement())
  child_id         Int
  sleep_start      DateTime
  sleep_end        DateTime?
  duration_minutes Int?
  quality          sleep_logs_quality? @default(good)
  notes            String?             @db.Text
  created_at       DateTime            @default(now())
  children         Child               @relation(fields: [child_id], references: [id], onDelete: Cascade)

  @@index([child_id], map: "sleep_logs_child_id_fkey")
}

model vaccination_records {
  id              Int                        @id @default(autoincrement())
  child_id        Int
  vaccination_id  Int
  status          vaccination_records_status @default(pending)
  dose_number     Int                        @default(1)
  administered_at DateTime?                  @db.Date
  next_due_at     DateTime?                  @db.Date
  administered_by Int?
  notes           String?                    @db.Text
  created_at      DateTime                   @default(now())
  users           User?                      @relation(fields: [administered_by], references: [id])
  children        Child                      @relation(fields: [child_id], references: [id], onDelete: Cascade)
  vaccinations    vaccinations               @relation(fields: [vaccination_id], references: [id])

  @@index([administered_by], map: "vaccination_records_administered_by_fkey")
  @@index([child_id], map: "vaccination_records_child_id_fkey")
  @@index([vaccination_id], map: "vaccination_records_vaccination_id_fkey")
}

model vaccinations {
  id                    Int                   @id @default(autoincrement())
  name                  String
  short_name            String?
  recommended_age_weeks Int?
  description           String?               @db.Text
  is_mandatory          Boolean               @default(true)
  doses_required        Int                   @default(1)
  vaccination_records   vaccination_records[]
}

enum feeding_logs_type {
  breastfeed
  bottle
  solid
}

enum milestones_category {
  motor
  cognitive
  social
  language
}

enum vaccination_records_status {
  pending
  done
  skipped
  overdue
}

enum children_gender {
  male
  female
  other
}

enum ai_queries_query_type {
  general
  risk_check
  milestone
  vaccination
  nutrition
}

enum feeding_logs_side {
  left
  right
  both
}

enum sleep_logs_quality {
  poor
  fair
  good
  excellent
}

enum children_journey_type {
  prenatal
  postnatal
}

enum users_role {
  parent
  health_worker
}
