generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  parent
  health_worker
}

enum FeedingMethod {
  breastfed
  bottle_breast_milk
  bottle_formula
  spoon_fed
  cup_fed
  self_fed
  tube_fed
  mixed
}

enum BreastSide {
  left
  right
  both
}

enum FeedingDifficulty {
  easy
  moderate
  difficult
  refused
}

enum FoodConsistency {
  liquid
  puree
  mashed
  minced
  soft_pieces
  regular
}

enum SleepType {
  nap
  night
  rest
}

enum SleepQuality {
  good
  fair
  poor
}

enum ActivityType {
  tummy_time
  play
  bath
  outdoor
  reading
  massage
  music
  other
}

enum MilestoneDomain {
  motor
  language
  social
  cognitive
  health
}

enum FoodCategory {
  breast_milk
  formula
  water
  juice
  grains_cereals
  legumes
  fish
  meat_poultry
  egg
  vegetables
  fruits
  dairy
  mixed_meal
  commercial_baby_food
  snack
  other
}

// ── Administrative Location Hierarchy ────────────────────────────────────────

model Division {
  id        Int      @id @default(autoincrement())
  nameBn    String   @map("name_bn")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  districts     District[]
  parents       Parent[]
  healthWorkers HealthWorker[]
  children      Child[]

  @@map("divisions")
}

model District {
  id         Int      @id @default(autoincrement())
  divisionId Int      @map("division_id")
  nameBn     String   @map("name_bn")
  nameEn     String   @map("name_en")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  division      Division   @relation(fields: [divisionId], references: [id])
  upazilas      Upazilla[]
  parents       Parent[]
  healthWorkers HealthWorker[]
  children      Child[]

  @@map("districts")
}

model Upazilla {
  id         Int      @id @default(autoincrement())
  districtId Int      @map("district_id")
  nameBn     String   @map("name_bn")
  nameEn     String   @map("name_en")
  isUrban    Boolean  @default(false) @map("is_urban")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  district      District       @relation(fields: [districtId], references: [id])
  parents       Parent[]
  healthWorkers HealthWorker[]
  children      Child[]

  @@map("upazilas")
}

// ── User Management ──────────────────────────────────────────────────────────

model User {
  id         Int      @id @default(autoincrement())
  phone      String   @unique
  fullNameBn String   @map("full_name_bn")
  fullNameEn String?  @map("full_name_en")
  password   String
  role       UserRole
  onboarded  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  parent             Parent?
  healthWorker       HealthWorker?
  growthMeasurements GrowthMeasurement[]
  illnessRecords     IllnessRecord[]
  feedingSessions    FeedingSession[]
  sleepSessions      SleepSession[]
  activitySessions   ActivitySession[]
  milestoneChecks    ChildMilestone[]   @relation("MilestoneCheckedBy")

  @@map("users")
}

model Parent {
  id                Int       @id @default(autoincrement())
  userId            Int       @unique @map("user_id")
  isPregnant        Boolean   @default(false) @map("is_pregnant")
  dateOfBirth       DateTime? @map("date_of_birth")
  pregnancyDuration Int?      @map("pregnancy_duration")
  weight            Float?
  upazillaId        Int       @map("upazilla_id")
  districtId        Int       @map("district_id")
  divisionId        Int       @map("division_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id])
  upazilla Upazilla @relation(fields: [upazillaId], references: [id])
  district District @relation(fields: [districtId], references: [id])
  division Division @relation(fields: [divisionId], references: [id])
  children         Child[]
  healthConditions ParentHealthCondition[]

  @@map("parents")
}

model ParentHealthCondition {
  id          Int      @id @default(autoincrement())
  parentId    Int      @map("parent_id")
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent Parent @relation(fields: [parentId], references: [id])

  @@map("parent_health_conditions")
}

model HealthWorker {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique @map("user_id")
  upazillaId Int      @map("upazilla_id")
  districtId Int      @map("district_id")
  divisionId Int      @map("division_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id])
  upazilla Upazilla @relation(fields: [upazillaId], references: [id])
  district District @relation(fields: [districtId], references: [id])
  division Division @relation(fields: [divisionId], references: [id])

  @@map("health_workers")
}

// ── Child & Health Tracking ──────────────────────────────────────────────────

model Child {
  id                     Int       @id @default(autoincrement())
  parentId               Int       @map("parent_id")
  fullNameBn             String    @map("full_name_bn")
  fullNameEn             String?   @map("full_name_en")
  gender                 String
  expectedDeliveryDate   DateTime? @map("expected_delivery_date")
  dateOfBirth            DateTime? @map("date_of_birth")
  bloodGroup             String?   @map("blood_group")
  birthLocation          String?   @map("birth_location")
  motherAgeAtEdd         Int?      @map("mother_age_at_edd")
  pregnancyComplications String?   @db.Text @map("pregnancy_complications")
  isBreastfed            Boolean   @default(false) @map("is_breastfed")
  birthComplications     String?   @db.Text @map("birth_complications")
  upazillaId             Int       @map("upazilla_id")
  districtId             Int       @map("district_id")
  divisionId             Int       @map("division_id")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  parent             Parent    @relation(fields: [parentId], references: [id])
  upazilla           Upazilla  @relation(fields: [upazillaId], references: [id])
  district           District  @relation(fields: [districtId], references: [id])
  division           Division  @relation(fields: [divisionId], references: [id])
  growthMeasurements GrowthMeasurement[]
  illnessRecords     IllnessRecord[]
  vaccinations       ChildVaccination[]
  feedingSessions    FeedingSession[]
  sleepSessions      SleepSession[]
  activitySessions   ActivitySession[]
  childMilestones    ChildMilestone[]

  @@map("children")
}

model GrowthMeasurement {
  id         Int      @id @default(autoincrement())
  childId    Int      @map("child_id")
  measuredBy Int      @map("measured_by")
  measuredAt DateTime @map("measured_at")
  ageDays    Int      @map("age_days")
  weightKg              Float    @map("weight_kg")
  heightCm              Float    @map("height_cm")
  headCircumferenceCm   Float?   @map("head_circumference_cm")
  notes                 String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  child          Child @relation(fields: [childId], references: [id])
  measuredByUser User  @relation(fields: [measuredBy], references: [id])

  @@map("growth_measurements")
}

model IllnessRecord {
  id             Int       @id @default(autoincrement())
  childId        Int       @map("child_id")
  recordedBy     Int       @map("recorded_by")
  recordedAt     DateTime  @map("recorded_at")
  disease        String
  symptoms       String?   @db.Text
  treatmentGiven String?   @db.Text @map("treatment_given")
  doctorName     String?   @map("doctor_name")
  facilityName   String?   @map("facility_name")
  resolved       Boolean   @default(false)
  resolvedDate   DateTime? @map("resolved_date")
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  child          Child @relation(fields: [childId], references: [id])
  recordedByUser User  @relation(fields: [recordedBy], references: [id])

  @@map("illness_records")
}

// Vaccine master list — required for ChildVaccination.vaccineId FK.
// Seed this with the Bangladesh EPI schedule (BCG, OPV, Pentavalent, PCV, IPV, MR, Vitamin A).
model Vaccine {
  id        Int      @id @default(autoincrement())
  nameEn    String   @map("name_en")
  nameBn    String   @map("name_bn")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relation to its specific doses
  doses     VaccineDose[]

  @@map("vaccines")
}

model VaccineDose {
  id              Int      @id @default(autoincrement())
  vaccineId       Int      @map("vaccine_id")
  doseNumber      Int      @map("dose_number") // For sorting and dependency logic (1, 2, 3)
  nameEn          String   @map("name_en")     // e.g., "Penta 1"
  nameBn          String   @map("name_bn")     // e.g., "পেন্টা ১"
  eligibleAgeDays Int      @map("eligible_age_days") // Age in days required for automatic scheduling
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  vaccine      Vaccine            @relation(fields: [vaccineId], references: [id])
  vaccinations ChildVaccination[]

  @@map("vaccine_doses")
}

model ChildVaccination {
  id            Int       @id @default(autoincrement())
  childId       Int       @map("child_id")
  vaccineDoseId Int       @map("vaccine_dose_id") // Swapped vaccineId out for vaccineDoseId
  scheduledDate DateTime  @map("scheduled_date")
  givenDate     DateTime? @map("given_date")
  facilityName  String?   @map("facility_name")
  isGiven       Boolean   @default(false) @map("is_given")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  child       Child       @relation(fields: [childId], references: [id])
  vaccineDose VaccineDose @relation(fields: [vaccineDoseId], references: [id])

  @@map("child_vaccinations")
}

// ── Feeding Tracking ─────────────────────────────────────────────────────────

model FeedingSession {
  id               Int               @id @default(autoincrement())
  childId          Int               @map("child_id")
  loggedBy         Int               @map("logged_by")
  fedAt            DateTime          @map("fed_at")
  method           FeedingMethod

  // Breastfeeding-specific
  breastSide       BreastSide?       @map("breast_side")
  durationMinutes  Int?              @map("duration_minutes")

  // Bottle / liquid-only sessions (formula or expressed breast milk)
  amountMl         Float?            @map("amount_ml")

  // Child's state during the feed
  mood             String?           // free text: happy, fussy, drowsy, crying, sleepy
  appetite         FeedingDifficulty?

  // Post-feeding flags
  vomitedAfter     Boolean           @default(false) @map("vomited_after")
  choked           Boolean           @default(false)
  allergicReaction Boolean           @default(false) @map("allergic_reaction")

  notes            String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  child            Child             @relation(fields: [childId], references: [id])
  loggedByUser     User              @relation(fields: [loggedBy], references: [id])
  items            FeedingItem[]

  @@map("feeding_sessions")
}

model FeedingItem {
  id                Int              @id @default(autoincrement())
  sessionId         Int              @map("session_id")
  foodNameBn        String           @map("food_name_bn")
  foodNameEn        String?          @map("food_name_en")
  category          FoodCategory
  consistency       FoodConsistency?

  // Amount — use whichever fits; amountDescription handles non-standard servings
  amountGrams       Float?           @map("amount_grams")
  amountMl          Float?           @map("amount_ml")
  amountDescription String?          @map("amount_description") // e.g. "2 tablespoons", "half a bowl"

  // Introduction & tolerance tracking
  isNewFood         Boolean          @default(false) @map("is_new_food")
  accepted          Boolean?         // null = partial, true = fully eaten, false = refused
  reaction          String?          @db.Text // reaction specific to this food item

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  session           FeedingSession   @relation(fields: [sessionId], references: [id])

  @@map("feeding_items")
}

// ── Sleep Tracking ────────────────────────────────────────────────────────────

model SleepSession {
  id              Int           @id @default(autoincrement())
  childId         Int           @map("child_id")
  loggedBy        Int           @map("logged_by")
  startedAt       DateTime      @map("started_at")
  endedAt         DateTime?     @map("ended_at")
  type            SleepType
  quality         SleepQuality?
  location        String?       // e.g. "crib", "arms", "stroller"
  notes           String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  child           Child         @relation(fields: [childId], references: [id])
  loggedByUser    User          @relation(fields: [loggedBy], references: [id])

  @@map("sleep_sessions")
}

// ── Activity Tracking ─────────────────────────────────────────────────────────

model ActivitySession {
  id              Int          @id @default(autoincrement())
  childId         Int          @map("child_id")
  loggedBy        Int          @map("logged_by")
  startedAt       DateTime     @map("started_at")
  durationMinutes Int?         @map("duration_minutes")
  type            ActivityType
  notes           String?      @db.Text
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  child           Child        @relation(fields: [childId], references: [id])
  loggedByUser    User         @relation(fields: [loggedBy], references: [id])

  @@map("activity_sessions")
}

// ── Milestone Tracking ────────────────────────────────────────────────────────

model Milestone {
  id           Int             @id @default(autoincrement())
  ageBracket   String          @map("age_bracket") // prenatal | 0-1m | 1-6m | 6-12m | 1-2y | 2-3y | 3-5y
  domain       MilestoneDomain
  textEn       String          @map("text_en") @db.Text
  textBn       String?         @map("text_bn") @db.Text
  sortOrder    Int             @default(0) @map("sort_order")
  source       String?         // WHO | DGHS | EPI
  minAgeMonths Int?            @map("min_age_months") // earliest expected age
  maxAgeMonths Int?            @map("max_age_months") // latest before flagging
  isKey        Boolean         @default(false) @map("is_key") // red-flag milestone
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  childMilestones ChildMilestone[]

  @@map("milestones")
}

model ChildMilestone {
  id          Int       @id @default(autoincrement())
  childId     Int       @map("child_id")
  milestoneId Int       @map("milestone_id")
  isAchieved  Boolean   @default(false) @map("is_achieved")
  achievedAt  DateTime? @map("achieved_at")
  checkedBy   Int?      @map("checked_by")
  notes       String?   @db.Text
  flagged     Boolean   @default(false) // parent marked as concern
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  child         Child     @relation(fields: [childId], references: [id])
  milestone     Milestone @relation(fields: [milestoneId], references: [id])
  checkedByUser User?     @relation("MilestoneCheckedBy", fields: [checkedBy], references: [id])

  @@unique([childId, milestoneId])
  @@map("child_milestones")
}
